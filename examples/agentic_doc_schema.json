{
  "asyncapi_version": "2.5.0",
  "events": [
    {
      "ack_schema": {
        "description": "Ack model returned immediately after a prompt is accepted.",
        "properties": {
          "accepted": {
            "default": true,
            "description": "Whether the prompt was accepted",
            "title": "Accepted",
            "type": "boolean"
          },
          "request_id": {
            "description": "Server-generated request identifier",
            "title": "Request Id",
            "type": "string"
          }
        },
        "required": [
          "request_id"
        ],
        "title": "AskAssistantResponse",
        "type": "object"
      },
      "ack_schema_component": "AskAssistantResponse",
      "description": "Accept a user prompt and start asynchronous assistant processing.",
      "direction": "client_to_server",
      "input_schema": {
        "deprecated": false,
        "description": "Request model for sending a user prompt to the assistant.",
        "properties": {
          "conversation_id": {
            "description": "Conversation identifier for multi-turn chats",
            "example": "chat-123",
            "title": "Conversation Id",
            "type": "string"
          },
          "prompt": {
            "description": "Natural-language prompt from the user",
            "title": "Prompt",
            "type": "string"
          }
        },
        "required": [
          "prompt"
        ],
        "title": "AskAssistantRequest",
        "type": "object",
        "x-component-ref": "#/components/schemas/AskAssistantRequest"
      },
      "input_schema_component": "AskAssistantRequest",
      "message_component": "Ask_Assistant",
      "name": "ask_assistant",
      "namespace": "/"
    },
    {
      "description": "Server push event sent when the assistant has produced a reply.",
      "direction": "server_to_client",
      "message_component": "assistant_reply",
      "name": "assistant_reply",
      "namespace": "/",
      "output_schema": {
        "deprecated": false,
        "description": "Server push event containing the assistant's generated reply.",
        "properties": {
          "message": {
            "description": "Generated reply text",
            "title": "Message",
            "type": "string"
          },
          "request_id": {
            "description": "Identifier of the related request",
            "title": "Request Id",
            "type": "string"
          }
        },
        "required": [
          "request_id",
          "message"
        ],
        "title": "AssistantReply",
        "type": "object",
        "x-component-ref": "#/components/schemas/AssistantReply"
      },
      "output_schema_component": "AssistantReply"
    }
  ],
  "format": "sio-asyncapi-agent-schema",
  "info": {
    "description": "Demo server that exports both AsyncAPI and agent-friendly schemas.\n<br/> AsyncAPI currently does not support Socket.IO binding and Web Socket like syntax used for now.\nIn order to add support for Socket.IO ACK value, AsyncAPI is extended with with x-ack keyword.\nThis documentation should **NOT** be used for generating code due to these limitations.\n",
    "title": "Agent Export Demo",
    "version": "1.0.0"
  },
  "servers": {
    "AGENT_EXPORT_DEMO": {
      "protocol": "socketio",
      "url": "http://localhost:5000"
    }
  },
  "version": "1.0"
}